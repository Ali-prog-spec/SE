<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="800" prefWidth="1200" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FinanceOfficer.MainLayoutController">

    <!-- CENTER contains the sidebar (full height) + right area (header + main) -->
    <center>
        <HBox>

            <!-- SIDEBAR: full height of the window -->
            <!-- SIDEBAR: full height of the window -->
                <VBox prefWidth="250" style="-fx-background-color: white; -fx-padding: 0;">
                    
                    <!-- Logo area at the very top — height matches header -->
                    <StackPane fx:id="sidebarLogo" alignment="CENTER" prefHeight="70" style="-fx-background-color: white; -fx-border-color: transparent #E5E7EB #E5E7EB transparent;">
                        <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="BRIX" />
                    </StackPane>

                    <!-- Buttons block only -->
                    <VBox spacing="15" style="-fx-padding: 20; -fx-border-color: transparent #E5E7EB transparent transparent;" VBox.vgrow="ALWAYS">

                        <Button onAction="#handleDashboard" prefWidth="210" styleClass="sidebar-button" text="Dashboard">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20">
                                    <image><Image url="@../icons/dashboard.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button onAction="#handleAddExpense" prefWidth="210" styleClass="sidebar-button" text="Add Expense">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20">
                                    <image><Image url="@../icons/expense.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button onAction="#handleCreateInvoice" prefWidth="210" styleClass="sidebar-button" text="Create Invoice">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20">
                                    <image><Image url="@../icons/invoice.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button onAction="#handleBudgetMonitor" prefWidth="210" styleClass="sidebar-button" text="Budget Monitor">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20">
                                    <image><Image url="@../icons/budget.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                         <Button onAction="#handleNoti" prefWidth="210" styleClass="sidebar-button" text="Notifications">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20">
                                    <image><Image url="@../icons/alert.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Pane VBox.vgrow="ALWAYS" /> <!-- pushes buttons to top -->
                    </VBox>
                </VBox>


            <!-- RIGHT AREA: header (only spans to window end) + main content below -->
            <VBox HBox.hgrow="ALWAYS">

              <StackPane prefHeight="70" style="-fx-background-color: white;" VBox.vgrow="NEVER">

                <HBox alignment="CENTER_LEFT" minHeight="70.0"
                    style="-fx-padding: 0 20; -fx-border-color: transparent transparent #E5E7EB transparent;"
                    HBox.hgrow="ALWAYS">

                    <!-- Dashboard Title -->
                    <Label style="-fx-text-fill: black; -fx-font-size: 22; -fx-font-weight: bold;"
                        text="Finance Dashboard" />

                    <Pane HBox.hgrow="ALWAYS" /> <!-- Push items to right -->

                    <!-- Logout Button -->
                    <Button text="Logout"
                            onAction="#handlelogOut"
                            style="-fx-background-color: red; -fx-text-fill: white;
                                -fx-background-radius: 8; -fx-padding: 6 14;"/>

                    <Pane minWidth="15"/> <!-- Spacer -->

                    <!-- Profile icon -->
                    <StackPane prefHeight="40" prefWidth="40">
                        <Circle fill="#3498db" radius="20" />
                        <Label alignment="CENTER"
                            style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16;"
                            text="A" />
                    </StackPane>

                </HBox>
            </StackPane>


                <!-- MAIN CONTENT fills the remaining area under the header -->
                <StackPane fx:id="mainContent" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
                    <Label style="-fx-font-size: 20;" text="Main Content Area" />
                </StackPane>
            </VBox>
        </HBox>
    </center>

</BorderPane>
