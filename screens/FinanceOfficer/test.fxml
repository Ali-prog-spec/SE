<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            prefWidth="900" prefHeight="600">

    <!-- Put the dashboard card in the center -->
    <VBox layoutX="40" layoutY="40" spacing="20" AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">

        <!-- ======= Quick Actions Card ======= -->
        <VBox spacing="15"
              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20;
                     -fx-border-color: #ddd; -fx-border-radius: 8;">

            <!-- Header -->
            <VBox spacing="5">
                <Label text="Quick Actions"
                       style="-fx-font-size: 18; -fx-font-weight: bold;" />

                <Label text="Financial operations"
                       style="-fx-text-fill: #666;" />
            </VBox>

            <!-- Grid of Buttons -->
            <GridPane hgap="15" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                </columnConstraints>

                <!-- 1. Create Invoice -->
                <Button GridPane.columnIndex="0"
                        onAction="#handleCreateInvoice"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;
                               -fx-padding: 15; -fx-background-radius: 8;">
                    <VBox spacing="5" alignment="CENTER">
                        <ImageView fitWidth="24" fitHeight="24">
                            <image>
                                <Image url="@../icons/invoice.png"/>
                            </image>
                        </ImageView>
                        <Label text="Create Invoice"/>
                    </VBox>
                </Button>

                <!-- 2. Add Expense -->
                <Button GridPane.columnIndex="1"
                        onAction="#handleAddExpense"
                        style="-fx-background-color: transparent; -fx-border-color: #ccc;
                               -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 15;">
                    <VBox spacing="5" alignment="CENTER">
                        <ImageView fitWidth="24" fitHeight="24">
                            <image>
                                <Image url="@../icons/expense.png"/>
                            </image>
                        </ImageView>
                        <Label text="Add Expense"/>
                    </VBox>
                </Button>

                <!-- 3. View Expenses -->
                <Button GridPane.columnIndex="2"
                        onAction="#handleExpensesList"
                        style="-fx-background-color: transparent; -fx-border-color: #ccc;
                               -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 15;">
                    <VBox spacing="5" alignment="CENTER">
                        <ImageView fitWidth="24" fitHeight="24">
                            <image>
                                <Image url="@../icons/receipt.png"/>
                            </image>
                        </ImageView>
                        <Label text="View All Expenses"/>
                    </VBox>
                </Button>

                <!-- 4. Budget Monitor -->
                <Button GridPane.columnIndex="3"
                        onAction="#handleBudgetMonitor"
                        style="-fx-background-color: transparent; -fx-border-color: #ccc;
                               -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 15;">
                    <VBox spacing="5" alignment="CENTER">
                        <ImageView fitWidth="24" fitHeight="24">
                            <image>
                                <Image url="@../icons/monitor.png"/>
                            </image>
                        </ImageView>
                        <Label text="Monitor Budget"/>
                    </VBox>
                </Button>

            </GridPane>

        </VBox>

    </VBox>

</AnchorPane>
