<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>


<VBox spacing="20" alignment="TOP_LEFT" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" prefWidth="1200"
      fx:controller="controllers.FinanceOfficer.FinanceDashboardController"
      >

    <!-- Header -->
    <VBox spacing="2">
        <Label text="Finance Officer Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Label text="Financial overview and budget management" style="-fx-text-fill: gray;" />
    </VBox>

    <!-- Summary Cards -->
    <GridPane hgap="20" vgap="20">
        <columnConstraints>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
        </columnConstraints>

        <!-- Card 1: Total Invoices -->
        <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, #cccccc, 5, 0, 0, 1);">
            <Label text="Total Invoices" style="-fx-font-weight: bold; -fx-font-size: 12;" />
            <Label fx:id="lblTotalInvoices" text="-" style="-fx-font-size: 20;" />
            <Label text="Created this month" style="-fx-text-fill: gray; -fx-font-size: 10;" />
        </VBox>

        <!-- Card 2: Pending Approvals -->
        <VBox GridPane.columnIndex="1" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, #cccccc, 5, 0, 0, 1);">
            <Label text="Pending Approvals" style="-fx-font-weight: bold; -fx-font-size: 12;" />
            <Label fx:id="lblPendingApprovals" text="-" style="-fx-font-size: 20;" />
            <Label text="Requiring action" style="-fx-text-fill: gray; -fx-font-size: 10;" />
        </VBox>

        <!-- Card 3: Total Expenses -->
        <VBox GridPane.columnIndex="2" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, #cccccc, 5, 0, 0, 1);">
            <Label text="Total Expenses" style="-fx-font-weight: bold; -fx-font-size: 12;" />
            <Label fx:id="lblTotalExpenses" text="-" style="-fx-font-size: 20;" />
            <Label text="Since last quarter" style="-fx-text-fill: gray; -fx-font-size: 10;" />
        </VBox>

        <!-- Card 4: Budget Status -->
        <VBox GridPane.columnIndex="3" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, #cccccc, 5, 0, 0, 1);">
            <Label text="Budget Status" style="-fx-font-weight: bold; -fx-font-size: 12;" />
            <Label fx:id="lblBudgetStatus" text="-" style="-fx-font-size: 20;" />
            <Label text="Budget utilized" style="-fx-text-fill: gray; -fx-font-size: 10;" />
        </VBox>

    </GridPane>

    <!-- Charts Section -->
    <GridPane hgap="20">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <!-- Line Chart -->
        <!-- Bar Chart: Budget vs Expenses -->
        <VBox spacing="8">
            <Label text="Budget vs Expenses" style="-fx-font-weight: bold; -fx-font-size: 16;" />
            <BarChart fx:id="budgetVsExpensesChart" GridPane.columnIndex="0">
                <xAxis>
                    <CategoryAxis label="Projects"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Amount"/>
                </yAxis>
            </BarChart>
        </VBox>


        <!-- Bar Chart -->
        <VBox GridPane.columnIndex="1" spacing="8">
            <Label text="Expense Distribution"  style="-fx-font-weight: bold; -fx-font-size: 16;" />
            <BarChart fx:id="expenseBarChart">
                <xAxis>
                    <CategoryAxis label="Category"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Amount"/>
                </yAxis>
            </BarChart>
        </VBox>
    </GridPane>

    <!-- Quick Actions -->
    <VBox spacing="15"
      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20;
             -fx-border-color: #ddd; -fx-border-radius: 8;">

    <!-- ==== Card Header ==== -->
    <VBox spacing="5">
        <Label text="Quick Actions" 
               style="-fx-font-size: 18; -fx-font-weight: bold;" />

        <Label text="Financial operations" 
               style="-fx-text-fill: #666;" />
    </VBox>

    <!-- Quick Actions Buttons -->
<GridPane hgap="10" vgap="10"> <!-- reduced gaps -->
    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
    </columnConstraints>

    <!-- ========== BUTTON 1: CREATE INVOICE ========== -->
    <Button GridPane.columnIndex="0" prefWidth="150"
            onAction="#handleCreateInvoice"
            style="-fx-background-color: #3498db; -fx-text-fill: white; 
                   -fx-padding: 15; -fx-background-radius: 8;">
        <graphic>
            <VBox spacing="5" alignment="CENTER">
                <ImageView fitWidth="24" fitHeight="24">
                    <image>
                        <Image url="@../icons/invoice.png"/>
                    </image>
                </ImageView>
                <Label text="Create Invoice" style="-fx-text-fill: white; -fx-font-weight: bold;" />
            </VBox>
        </graphic>
    </Button>

    <!-- ========== BUTTON 2: ADD EXPENSE ========== -->
    <Button GridPane.columnIndex="1" prefWidth="150"
            onAction="#handleAddExpense"
            style="-fx-background-color: transparent; -fx-border-color: #ccc; 
                   -fx-background-radius: 8; -fx-border-radius: 8;
                   -fx-padding: 15;">
        <graphic>
            <VBox spacing="5" alignment="CENTER">
                <ImageView fitWidth="24" fitHeight="24">
                    <image>
                        <Image url="@../icons/expense.png"/>
                    </image>
                </ImageView>
                <Label text="Add Expense" style="-fx-font-weight: bold;" />
            </VBox>
        </graphic>
    </Button>

    <!-- ========== BUTTON 3: VIEW ALL EXPENSES ========== -->
    <Button GridPane.columnIndex="2" prefWidth="150"
            onAction="#handleAddExpense"
            style="-fx-background-color: transparent; -fx-border-color: #ccc; 
                   -fx-background-radius: 8; -fx-border-radius: 8;
                   -fx-padding: 15;">
        <graphic>
            <VBox spacing="5" alignment="CENTER">
                <ImageView fitWidth="24" fitHeight="24">
                    <image>
                        <Image url="@../icons/receipt.png"/>
                    </image>
                </ImageView>
                <Label text="View All Expenses" style="-fx-font-weight: bold;" />
            </VBox>
        </graphic>
    </Button>

    <!-- ========== BUTTON 4: MONITOR BUDGET ========== -->
    <Button GridPane.columnIndex="3" prefWidth="150"
            onAction="#handleMonitorBudget"
            style="-fx-background-color: transparent; -fx-border-color: #ccc; 
                   -fx-background-radius: 8; -fx-border-radius: 8;
                   -fx-padding: 15;">
        <graphic>
            <VBox spacing="5" alignment="CENTER">
                <ImageView fitWidth="24" fitHeight="24">
                    <image>
                        <Image url="@../icons/monitor.png"/>
                    </image>
                </ImageView>
                <Label text="Monitor Budget" style="-fx-font-weight: bold;" />
            </VBox>
        </graphic>
    </Button>
</GridPane>


    </VBox>


    

</VBox>
