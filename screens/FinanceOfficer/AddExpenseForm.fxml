<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.FinanceOfficer.AddExpenseController"
      spacing="20"
      prefWidth="800"
      alignment="TOP_CENTER">

    <!-- Breadcrumb -->
    <HBox spacing="5">
        <Hyperlink text="Dashboard"/>
        <Label text="/" />
        <Label text="Add Expense" style="-fx-font-weight: bold;" />
    </HBox>

    <!-- Main Card -->
    <VBox spacing="20" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.15),10,0.1,0,2);"
          maxWidth="700">

        <!-- Header: Title + Back Button -->
        <HBox alignment="CENTER_RIGHT">
            <VBox alignment="CENTER_LEFT" spacing="2">
                <Label text="Add Expense" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                <Label text="Record project expenses and costs" />
            </VBox>

            <Button text="Back" fx:id="btnBack"/>
        </HBox>

        <!-- Form Grid -->
        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <!-- Project -->
            <Label text="Project *" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="projectCombo" promptText="Select project"
                      GridPane.rowIndex="1" GridPane.columnIndex="0"/>

            <!-- Date -->
            <Label text="Date *" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <DatePicker fx:id="datePicker"
                        GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- Category -->
            <Label text="Category *" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="categoryCombo" promptText="Select category"
                      GridPane.rowIndex="3" GridPane.columnIndex="0"/>

            <!-- Amount -->
            <Label text="Amount ($) *" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <TextField fx:id="amountField" promptText="0.00"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <!-- Description full width -->
            <Label text="Description *" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextArea fx:id="descriptionArea"
                      promptText="Describe the expense..."
                      prefRowCount="4"
                      GridPane.rowIndex="5"
                      GridPane.columnIndex="0"
                      GridPane.columnSpan="2"/>
        </GridPane>

        <!-- Buttons -->
        <HBox spacing="15">
            <Button text="Add Expense" fx:id="btnSubmit" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button text="Cancel" fx:id="btnCancel"/>
        </HBox>

    </VBox>

    <!-- Success Dialog (Hidden by default) -->
    <StackPane fx:id="successPane"
               visible="false"
               style="-fx-background-color: rgba(0,0,0,0.25); -fx-padding: 40;">

        <VBox spacing="15" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

            <Label text="✔" style="-fx-font-size: 40px; -fx-text-fill: green;" />

            <Label text="Expense Added Successfully!"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label fx:id="successMessage"
                   text="Expense added."
                   wrapText="true"/>
        </VBox>
    </StackPane>

</VBox>
